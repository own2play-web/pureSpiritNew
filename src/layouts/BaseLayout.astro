---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
import site from '../data/site.json';

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const {
  title,
  description = 'Pure Spirit – Bachbloesemtherapie, Meditatie, Coaching, Begeleiding HSP en Persoonlijke Ontwikkeling in Oss.',
  image = '/uploads/pure-spirit-logo-95px-hoog.png',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: site.naam,
  url: 'https://www.purespirit-oss.nl',
  telephone: site.telefoon,
  email: site.email,
  address: {
    '@type': 'PostalAddress',
    streetAddress: site.adres,
    postalCode: site.postcode,
    addressLocality: site.stad,
    addressCountry: 'NL',
  },
  openingHoursSpecification: [
    { '@type': 'OpeningHoursSpecification', dayOfWeek: ['Monday','Tuesday','Wednesday','Thursday','Friday'], opens: '09:00', closes: '21:30' },
  ],
  priceRange: '€€',
};
---

<!doctype html>
<html lang="nl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Pure Spirit Oss</title>
    <meta name="description" content={description} />

    <!-- Pre-release: niet indexeren -->
    <meta name="robots" content="noindex, nofollow" />

    <link rel="canonical" href={canonicalURL} />

    <!-- Preconnect voor externe scripts -->
    <link rel="preconnect" href="https://identity.netlify.com" />

    <!-- Open Graph -->
    <meta property="og:type"        content="website" />
    <meta property="og:url"         content={canonicalURL} />
    <meta property="og:title"       content={`${title} | Pure Spirit Oss`} />
    <meta property="og:description" content={description} />
    <meta property="og:image"       content={new URL(image, Astro.site)} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- LocalBusiness structured data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <!-- Netlify Identity (verplicht voor CMS redirect) -->
    <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Naar inhoud</a>
    <Header />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style>
  .skip-link {
    position: absolute;
    top: -100%;
    left: var(--space-4);
    background: var(--color-primary);
    color: #fff;
    padding: var(--space-2) var(--space-4);
    border-radius: 0 0 var(--radius-md) var(--radius-md);
    font-weight: 700;
    text-decoration: none;
    z-index: 9999;
    transition: top 0.1s;
  }
  .skip-link:focus {
    top: 0;
  }
</style>
