---
import PageLayout from '../layouts/PageLayout.astro';
import ServiceCard from '../components/ServiceCard.astro';

const services = [
  {
    title: 'Bachbloesemtherapie',
    description: 'De Bachbloesemtherapie is een natuurlijke methode om weer balans te brengen in je emotionele leven. Heel geschikt bij overprikkeling, vermoeidheid, angst en onzekerheid. Zonder bijwerkingen.',
    href: '/bachbloesemtherapie/',
    icon: '🌸',
  },
  {
    title: 'Meditatie',
    description: 'Mediteer in een kleine, veilige groep van maximaal 6 personen. Voor alle leeftijden, van jongeren tot volwassenen. Leer je gedachten tot rust te brengen en meer bij jezelf te zijn.',
    href: '/meditatie/',
    icon: '🧘',
  },
  {
    title: 'Coaching',
    description: 'Pure Spirit verzorgt coachingstrajecten op maat, voor privé én zakelijk. Steun van iemand buiten je directe omgeving, met praktische handvatten die je meteen kunt toepassen.',
    href: '/coaching/',
    icon: '💬',
  },
  {
    title: 'Begeleiding HSP',
    description: 'Hooggevoeligheid kan veel vragen van je. Pure Spirit begeleidt volwassenen, jongeren en kinderen die hooggevoelig zijn, individueel of in een kleine groep, altijd op maat.',
    href: '/begeleiding-hsp/',
    icon: '💛',
  },
  {
    title: 'Persoonlijke groei',
    description: 'Workshops en cursussen gericht op persoonlijke ontwikkeling. Praktisch ingesteld, direct toepasbaar in je dagelijks leven en in een veilige, kleine groep.',
    href: '/persoonlijke-groei/',
    icon: '🌱',
  },
  {
    title: 'Privé consulten',
    description: 'Een persoonlijk consult, helemaal afgestemd op jouw situatie. In de praktijk in Oss, telefonisch of via Skype. Jij bepaalt wat voor jou het beste werkt.',
    href: '/contact/',
    icon: '🤝',
  },
];
---

<PageLayout
  title="Diensten"
  heroTitle="Onze diensten"
  heroSubtitle="Van Bachbloesemtherapie tot meditatiecursussen, altijd praktisch, persoonlijk en op maat."
>
  <section class="section">
    <div class="container">
      <div class="grid grid--3">
        {services.map(s => <ServiceCard {...s} />)}
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container container--narrow" style="text-align: center;">
      <h2>Niet zeker welke dienst bij jou past?</h2>
      <p class="lead" style="margin-bottom: var(--space-8);">
        Neem gerust contact op. We denken graag met je mee welke begeleiding
        het beste aansluit bij jouw situatie.
      </p>
      <a href="/contact/" class="btn btn--primary">Neem contact op</a>
    </div>
  </section>
</PageLayout>
