---
import PageLayout from '../layouts/PageLayout.astro';
import homepage from '../data/homepage.json';
import over from '../data/over.json';

const alineas = homepage.sasja_tekst.split('\n\n').filter(Boolean);
const { werkwijze, waarden } = over;
---

<PageLayout
  title="Over mij"
  heroTitle="Over Sasja van Geel"
  heroSubtitle="Begeleider bij Pure Spirit Oss — praktisch, niet-zweverig en altijd op maat."
  description="Maak kennis met Sasja van Geel van Pure Spirit Oss. Bachbloesemtherapeut, meditatiedocent, coach en HSP-begeleider."
>

  <!-- Persoonlijk verhaal -->
  <section class="section">
    <div class="container">
      <div class="over-grid">
        <div class="over-foto">
          <img
            src={homepage.sasja_foto}
            alt="Sasja van Geel – Pure Spirit Oss"
            class="sasja-foto"
          />
        </div>
        <div class="over-tekst">
          <span class="eyebrow">Wie ben ik?</span>
          <h2>Mijn verhaal</h2>
          <hr class="divider" style="margin: var(--space-4) 0 var(--space-6);" />
          {alineas.map((alinea, i) => (
            <p class={i === 0 ? 'lead' : ''}>{alinea}</p>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Werkwijze -->
  <section class="section section--alt">
    <div class="container">
      <div class="section__header">
        <h2>Mijn werkwijze</h2>
        <hr class="divider" />
        <p class="lead">Hoe ik werk en wat je van mij kunt verwachten.</p>
      </div>
      <div class="grid grid--3">
        {werkwijze.map(item => (
          <div class="werkwijze-kaart">
            <h3>{item.titel}</h3>
            <p>{item.tekst}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Kernwaarden -->
  <section class="section">
    <div class="container container--narrow">
      <div class="section__header">
        <h2>Kernwaarden</h2>
        <hr class="divider" />
      </div>
      <div class="waarden">
        {waarden.map(w => (
          <div class="waarde">
            <strong>{w.woord}</strong>
            <p>{w.uitleg}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section section--dark">
    <div class="container" style="text-align: center;">
      <h2>Kennismaken?</h2>
      <p class="lead" style="max-width: 500px; margin-inline: auto; margin-bottom: var(--space-8);">
        Neem vrijblijvend contact op. Ik denk graag met je mee welke begeleiding het beste bij jou past.
      </p>
      <div style="display: flex; gap: var(--space-4); justify-content: center; flex-wrap: wrap;">
        <a href="/contact/" class="btn btn--accent">Neem contact op</a>
        <a href="/diensten/" class="btn btn--outline" style="border-color: rgba(255,255,255,0.5); color: #fff;">
          Bekijk de diensten
        </a>
      </div>
    </div>
  </section>

</PageLayout>

<style>
  .over-grid {
    display: grid;
    grid-template-columns: 340px 1fr;
    gap: var(--space-16);
    align-items: start;
  }

  .sasja-foto {
    width: 100%;
    aspect-ratio: 4/5;
    object-fit: cover;
    object-position: center top;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
    display: block;
  }

  .eyebrow {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: var(--space-3);
  }

  .over-tekst p {
    margin-bottom: var(--space-4);
  }

  .werkwijze-kaart {
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-8);
  }

  .werkwijze-kaart h3 {
    margin-bottom: var(--space-3);
    color: var(--color-primary-dark);
  }

  .werkwijze-kaart p {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    line-height: 1.7;
    margin: 0;
  }

  .waarden {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .waarde {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: var(--space-6);
    align-items: baseline;
    padding: var(--space-5) var(--space-6);
    border-left: 3px solid var(--color-primary);
    background-color: var(--color-primary-light);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
  }

  .waarde strong {
    font-family: var(--font-heading);
    font-size: var(--text-lg);
    color: var(--color-primary-dark);
  }

  .waarde p {
    margin: 0;
    color: var(--color-text-muted);
  }

  @media (max-width: 900px) {
    .over-grid {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }

    .sasja-foto {
      aspect-ratio: 3/2;
      object-position: center 20%;
    }

    .waarde {
      grid-template-columns: 1fr;
      gap: var(--space-2);
    }
  }
</style>
