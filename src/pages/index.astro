---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ServiceCard from '../components/ServiceCard.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import NewsCard from '../components/NewsCard.astro';
import FAQ from '../components/FAQ.astro';
import { getCollection } from 'astro:content';
import homepage from '../data/homepage.json';
import faqData from '../data/faq.json';
import ervaringen from '../data/ervaringen.json';

// Nieuws
const allNieuws = await getCollection('nieuws');
const latestNieuws = allNieuws
  .sort((a, b) => new Date(b.data.datum).getTime() - new Date(a.data.datum).getTime())
  .slice(0, 3);

// Diensten uit content collection
const allDiensten = await getCollection('diensten');
const services = allDiensten
  .sort((a, b) => a.data.volgorde - b.data.volgorde)
  .map(d => ({
    title: d.data.titel,
    description: d.data.samenvatting,
    href: `/diensten/${d.slug}/`,
    icon: d.data.icon,
  }));

// FAQ uit JSON
const faqItems = faqData.items.map(item => ({
  question: item.vraag,
  answer:   item.antwoord,
}));

// Ervaringen uit JSON (eerste 6)
const testimonials = ervaringen.items.slice(0, 6);

// Homepage data
const sasjaAlineas = homepage.sasja_tekst.split('\n\n').filter(Boolean);
---

<BaseLayout
  title="Welkom"
  description="Pure Spirit in Oss biedt Bachbloesemtherapie, Meditatie, Coaching, Begeleiding HSP en Persoonlijke Ontwikkeling. Praktisch, niet-zweverig en op maat."
>
  <!-- Hero -->
  <Hero
    title={homepage.hero_titel}
    subtitle={homepage.hero_subtitel}
    cta={{ label: homepage.hero_cta_label, href: homepage.hero_cta_url }}
    ctaSecondary={{ label: homepage.hero_cta2_label, href: homepage.hero_cta2_url }}
    badge="Zuiverheid · Eenvoud · Kracht"
  />

  <!-- Actueel -->
  {homepage.actueel_actief && (
    <div class="actueel-bar">
      <div class="container">
        <span class="actueel-bar__label">Actueel</span>
        <p>
          {homepage.actueel_bericht}
          {homepage.actueel_link_url && (
            <a href={homepage.actueel_link_url}>{homepage.actueel_link_tekst} →</a>
          )}
        </p>
      </div>
    </div>
  )}

  <!-- Diensten -->
  <section class="section section--alt">
    <div class="container">
      <div class="section__header">
        <h2>Onze diensten</h2>
        <hr class="divider" />
        <p class="lead">Voor alle leeftijden — kinderen, jongeren en volwassenen. Altijd praktisch en op jouw maat.</p>
      </div>
      <div class="grid grid--3">
        {services.map(s => <ServiceCard {...s} />)}
      </div>
    </div>
  </section>

  <!-- HSP sectie -->
  <section class="section">
    <div class="container">
      <div class="hsp-grid">
        <div>
          <h2>Begeleiding voor hooggevoelige mensen</h2>
          <hr class="divider" style="margin: var(--space-4) 0 var(--space-6);" />
          <p>
            Een HSP'er is meer dan gemiddeld gevoelig voor indrukken en prikkels
            en merkt meer signalen en details op dan anderen. Dat kan heel zwaar zijn.
          </p>
          <p>
            Pure Spirit begeleidt volwassenen, jongeren en kinderen die hooggevoelig zijn.
            Dit kan individueel of in groepsverband. De oefeningen helpen je jezelf beter
            af te schermen voor prikkels van buitenaf — zodat je weer in je eigen kracht komt.
          </p>
          <p>
            Hooggevoeligheid bij kinderen wordt ook wel HSK (HoogSensitief Kind) genoemd.
            Herkenbare kenmerken zijn angsten, problemen met het zelfvertrouwen, een druk hoofd
            en moeilijk kunnen inslapen.
          </p>
          <a href="/diensten/begeleiding-hsp/" class="btn btn--outline" style="margin-top: var(--space-4);">Meer over HSP-begeleiding</a>
        </div>
        <div class="hsp-quote">
          <blockquote>
            "Je kind zien worstelen met het dagelijks leven doet pijn. We gaan samen
            kijken hoe we deze worsteling kunnen verzachten of zelfs verhelpen."
          </blockquote>
          <p class="text-muted" style="font-size: var(--text-sm); margin-top: var(--space-3);">— Sasja van Geel, Pure Spirit</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Ervaringen -->
  <section class="section section--alt">
    <div class="container">
      <div class="section__header">
        <h2>Wat anderen zeggen</h2>
        <hr class="divider" />
        <p class="lead">Je bent in goede handen bij Pure Spirit.</p>
      </div>
      <div class="grid grid--3">
        {testimonials.map(t => (
          <TestimonialCard quote={t.quote} author={t.author} service={t.service} />
        ))}
      </div>
      <div style="text-align: center; margin-top: var(--space-10);">
        <a href="/ervaringen/" class="btn btn--outline">Alle ervaringen</a>
      </div>
    </div>
  </section>

  <!-- Over Sasja van Geel -->
  <section class="section">
    <div class="container">
      <div class="about-grid">
        <div class="about-photo">
          <img src={homepage.sasja_foto} alt="Sasja van Geel – Pure Spirit Oss" class="sasja-photo" />
        </div>
        <div class="about-text">
          <span class="about-eyebrow">Wie ben ik?</span>
          <h2>{homepage.sasja_titel}</h2>
          <hr class="divider" style="margin: var(--space-4) 0 var(--space-6);" />
          {sasjaAlineas.map((alinea, i) => (
            <p class={i === 0 ? 'lead' : ''}>{alinea}</p>
          ))}
          <a href={homepage.sasja_cta_url} class="btn btn--primary" style="margin-top: var(--space-6);">
            {homepage.sasja_cta_label}
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Veelgestelde vragen -->
  <section class="section">
    <div class="container container--narrow">
      <div class="section__header">
        <h2>Veelgestelde vragen</h2>
        <hr class="divider" />
      </div>
      <FAQ items={faqItems} />
    </div>
  </section>

  <!-- Laatste nieuws -->
  {latestNieuws.length > 0 && (
    <section class="section section--alt">
      <div class="container">
        <div class="section__header">
          <h2>Laatste nieuws</h2>
          <hr class="divider" />
        </div>
        <div class="grid grid--3">
          {latestNieuws.map(post => (
            <NewsCard
              title={post.data.titel}
              date={post.data.datum}
              excerpt={post.data.samenvatting}
              href={`/nieuws/${post.slug}/`}
              category={post.data.categorie}
            />
          ))}
        </div>
        <div style="text-align: center; margin-top: var(--space-10);">
          <a href="/nieuws/" class="btn btn--outline">Alle nieuwsberichten</a>
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="section section--dark">
    <div class="container" style="text-align: center;">
      <h2>Klaar om te beginnen?</h2>
      <p class="lead" style="max-width: 520px; margin-inline: auto; margin-bottom: var(--space-8);">
        Neem vrijblijvend contact op. We denken graag met je mee welke begeleiding
        het beste bij jou past.
      </p>
      <div style="display: flex; gap: var(--space-4); justify-content: center; flex-wrap: wrap;">
        <a href="/contact/" class="btn btn--accent">Neem contact op</a>
        <a href="tel:0412692162" class="btn btn--outline" style="border-color: rgba(255,255,255,0.5); color: #fff;">
          Bel 0412 69 21 62
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .actueel-bar {
    background-color: var(--color-accent);
    color: #fff;
    padding-block: var(--space-3);
  }

  .actueel-bar .container {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .actueel-bar__label {
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    background-color: rgba(255,255,255,0.25);
    padding: 2px var(--space-3);
    border-radius: var(--radius-full);
    flex-shrink: 0;
  }

  .actueel-bar p {
    font-size: var(--text-sm);
    margin: 0;
    color: #fff;
  }

  .actueel-bar a {
    color: #fff;
    font-weight: 700;
  }

  .about-grid {
    display: grid;
    grid-template-columns: 360px 1fr;
    gap: var(--space-16);
    align-items: center;
  }

  .about-photo {
    position: relative;
  }

  .sasja-photo {
    width: 100%;
    aspect-ratio: 4/5;
    object-fit: cover;
    object-position: center top;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
    display: block;
  }

  .about-eyebrow {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: var(--space-3);
  }

  .hsp-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-16);
    align-items: center;
  }

  .hsp-quote {
    background-color: var(--color-primary-light);
    border-radius: var(--radius-lg);
    padding: var(--space-10);
  }

  .hsp-quote blockquote {
    font-family: var(--font-heading);
    font-style: italic;
    font-size: var(--text-xl);
    color: var(--color-primary-dark);
    line-height: 1.7;
    border: none;
    padding: 0;
    margin: 0;
  }

  @media (max-width: 900px) {
    .about-grid {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }
    .sasja-photo {
      aspect-ratio: 3/2;
      object-position: center 20%;
    }
    .hsp-grid { grid-template-columns: 1fr; gap: var(--space-10); }
  }
</style>
