---
import PageLayout from '../../layouts/PageLayout.astro';
import NewsCard from '../../components/NewsCard.astro';
import { getCollection } from 'astro:content';

const allNieuws = await getCollection('nieuws');
const sorted = allNieuws.sort(
  (a, b) => new Date(b.data.datum).getTime() - new Date(a.data.datum).getTime()
);
---

<PageLayout
  title="Nieuws"
  heroTitle="Nieuws"
  heroSubtitle="Het laatste nieuws van Pure Spirit — cursussen, tips en activiteiten."
  description="Nieuws en updates van Pure Spirit Oss over meditatiecursussen, Bachbloesemtherapie en persoonlijke ontwikkeling."
>
  <section class="section">
    <div class="container">
      <div class="grid grid--3">
        {sorted.map(post => (
          <NewsCard
            title={post.data.titel}
            date={post.data.datum}
            excerpt={post.data.samenvatting}
            href={`/nieuws/${post.slug}/`}
            category={post.data.categorie}
          />
        ))}
      </div>
    </div>
  </section>
</PageLayout>
