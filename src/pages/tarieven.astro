---
import PageLayout from '../layouts/PageLayout.astro';
import tarieven from '../data/tarieven.json';

// Eenvoudige markdown-renderer: **vet** → <strong>, alinea's op \n\n
function renderTekst(tekst: string): string[] {
  return tekst
    .split('\n\n')
    .map(p => p.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>'));
}
---

<PageLayout
  title="Tarieven"
  heroTitle="Tarieven"
  heroSubtitle="Transparante, eerlijke tarieven. Kosten zijn altijd goed te overzien."
  description="Tarieven voor Bachbloesemtherapie, Meditatie, Coaching en HSP-begeleiding bij Pure Spirit Oss."
>
  <section class="section">
    <div class="container">

      {tarieven.aankondiging && (
        <div class="notice">
          <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          <p>Bij Pure Spirit gelden de volgende tarieven. <strong>{tarieven.aankondiging}</strong></p>
        </div>
      )}

      <div class="hoofd-layout">

        <!-- Linkerkolom: tekst-secties -->
        <div class="uitleg-kolom">
          {tarieven.secties.map(sectie => (
            <article class="uitleg-sectie">
              <h2>{sectie.titel}</h2>
              {renderTekst(sectie.tekst).map(alinea => (
                <p set:html={alinea} />
              ))}
            </article>
          ))}
        </div>

        <!-- Rechterkolom: tarieftabel -->
        <div class="tabel-kolom">
          <div class="tabel-sticky">
            <h2 class="tabel-kop">{tarieven.tabel_titel}</h2>
            {tarieven.tabel_ondertitel && (
              <p class="tabel-sub">{tarieven.tabel_ondertitel}</p>
            )}

            <div class="tabel-card">
              {tarieven.groepen.map((groep, gi) => (
                <>
                  <div class="tabel-groephdr">{groep.naam}</div>
                  {groep.rijen.map((rij, ri) => {
                    const isLast = gi === tarieven.groepen.length - 1 && ri === groep.rijen.length - 1;
                    const isPrijs = rij.waarde.startsWith('€');
                    return (
                      <div class:list={['tabel-rij', isLast && 'tabel-rij--last']}>
                        <span>{rij.label}</span>
                        {isPrijs
                          ? <strong>{rij.waarde}</strong>
                          : <em>{rij.waarde}</em>
                        }
                      </div>
                    );
                  })}
                </>
              ))}
            </div>

            <a href="/contact/" class="btn btn--primary cta-btn">Afspraak maken</a>
          </div>
        </div>

      </div>
    </div>
  </section>
</PageLayout>

<style>
  .notice {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    background-color: var(--color-primary-light);
    border: 1px solid var(--color-border);
    border-left: 3px solid var(--color-primary);
    border-radius: var(--radius-md);
    padding: var(--space-4) var(--space-5);
    margin-bottom: var(--space-12);
    font-size: var(--text-sm);
    color: var(--color-text);
    line-height: 1.6;
  }

  .notice svg { flex-shrink: 0; color: var(--color-primary); margin-top: 2px; }
  .notice p   { margin: 0; }

  .hoofd-layout {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: var(--space-12);
    align-items: start;
  }

  .uitleg-kolom {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .uitleg-sectie {
    padding-block: var(--space-8);
    border-bottom: 1px solid var(--color-border);
  }

  .uitleg-sectie:first-child { padding-top: 0; }
  .uitleg-sectie:last-child  { border-bottom: none; }

  .uitleg-sectie h2 {
    font-size: var(--text-lg);
    color: var(--color-primary-dark);
    margin-bottom: var(--space-4);
  }

  .uitleg-sectie p {
    font-size: var(--text-sm);
    color: var(--color-text);
    line-height: 1.75;
    margin: 0 0 var(--space-3);
  }

  .uitleg-sectie p:last-child { margin-bottom: 0; }

  .tabel-kolom {
    position: relative;
  }

  .tabel-sticky {
    position: sticky;
    top: 100px;
  }

  .tabel-kop {
    font-size: var(--text-xl);
    color: var(--color-text);
    margin-bottom: var(--space-2);
  }

  .tabel-sub {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    line-height: 1.6;
    margin-bottom: var(--space-5);
  }

  .tabel-card {
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    margin-bottom: var(--space-5);
  }

  .tabel-groephdr {
    background-color: var(--color-surface-alt);
    padding: var(--space-2) var(--space-5);
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--color-primary);
    border-bottom: 1px solid var(--color-border);
  }

  .tabel-rij {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-3) var(--space-5);
    border-bottom: 1px solid var(--color-border);
    font-size: var(--text-sm);
    color: var(--color-text);
  }

  .tabel-rij--last { border-bottom: none; }

  .tabel-rij strong {
    font-family: var(--font-heading);
    font-size: var(--text-base);
    font-weight: 700;
    color: var(--color-primary-dark);
    white-space: nowrap;
  }

  .tabel-rij em {
    font-style: normal;
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    white-space: nowrap;
  }

  .cta-btn {
    width: 100%;
    justify-content: center;
  }

  @media (max-width: 860px) {
    .hoofd-layout {
      grid-template-columns: 1fr;
    }

    .tabel-sticky {
      position: static;
    }
  }
</style>
