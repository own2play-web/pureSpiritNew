---
import PageLayout from '../layouts/PageLayout.astro';
import ContactForm from '../components/ContactForm.astro';
import site from '../data/site.json';
---

<PageLayout
  title="Contact"
  heroTitle="Contact"
  heroSubtitle="Neem gerust contact op. We denken graag met je mee."
  description="Contact opnemen met Pure Spirit Oss. Bachbloesemtherapie, Meditatie, Coaching en HSP-begeleiding in Oss."
>
  <section class="section">
    <div class="container">
      <div class="contact-grid">
        <div>
          <h2>Stuur een bericht</h2>
          <p class="lead">
            Heb je een vraag, wil je je aanmelden voor een cursus, of wil je een afspraak maken?
            Vul het formulier in en we nemen zo snel mogelijk contact met je op.
          </p>
          <ContactForm />
        </div>

        <aside class="contact-info">
          <div class="info-card">
            <h3>Contactgegevens</h3>
            <dl>
              <dt>Praktijk</dt>
              <dd>{site.naam}</dd>
              <dt>Naam</dt>
              <dd>{site.eigenaar}</dd>
              <dt>Adres</dt>
              <dd>{site.adres}<br />{site.postcode} {site.stad}</dd>
              <dt>Telefoon</dt>
              <dd><a href={`tel:${site.telefoon.replace(/\s/g,'')}`}>{site.telefoon}</a></dd>
              <dt>E-mail</dt>
              <dd><a href={`mailto:${site.email}`}>{site.email}</a></dd>
              <dt>KVK</dt>
              <dd>{site.kvk}</dd>
            </dl>
          </div>

          <div class="info-card info-card--light">
            <h4>Openingstijden</h4>
            <dl>
              {site.openingstijden.map(o => (
                <>
                  <dt>{o.dag}</dt>
                  <dd>{o.tijd}</dd>
                </>
              ))}
            </dl>
            {site.openingstijden_opmerking && (
              <p style="margin-top: var(--space-4); font-size: var(--text-sm); color: var(--color-text-muted);">
                <em>{site.openingstijden_opmerking}</em>
              </p>
            )}
          </div>

          <div class="info-card info-card--warning">
            <h4>Let op: spam</h4>
            <p>
              E-mailreacties komen soms in de spamfolder terecht.
              Controleer je spam als je binnen 3 werkdagen niets hebt ontvangen,
              of bel ons op <a href={`tel:${site.telefoon.replace(/\s/g,'')}`}>{site.telefoon}</a>.
            </p>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <div class="kaart-header">
        <div>
          <h2>Hoe kom je bij ons?</h2>
          <p>{site.adres}, {site.postcode} {site.stad}</p>
        </div>
        <a
          href={`https://www.google.com/maps/dir/?api=1&destination=${encodeURIComponent(site.adres + ', ' + site.postcode + ' ' + site.stad)}`}
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn--outline"
        >
          Route plannen →
        </a>
      </div>
      <div class="kaart-wrapper">
        <iframe
          title="Locatie Pure Spirit Oss"
          src="https://www.openstreetmap.org/export/embed.html?bbox=5.5050%2C51.7504%2C5.5250%2C51.7604&layer=mapnik&marker=51.7554%2C5.5150"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </div>
      <p class="kaart-credit">
        Kaart via <a href="https://www.openstreetmap.org/node/Beethovengaarde+90+Oss" target="_blank" rel="noopener noreferrer">OpenStreetMap</a>
      </p>
    </div>
  </section>
</PageLayout>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 360px;
    gap: var(--space-16);
    align-items: start;
  }

  .contact-grid h2 {
    margin-bottom: var(--space-3);
  }

  .contact-grid .lead {
    margin-bottom: var(--space-8);
  }

  .contact-info {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    position: sticky;
    top: 100px;
  }

  .info-card {
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
  }

  .info-card h3 { font-size: var(--text-xl); margin-bottom: var(--space-5); }
  .info-card h4 { font-size: var(--text-base); margin-bottom: var(--space-4); }

  .info-card--light {
    background-color: var(--color-primary-light);
    border-color: transparent;
  }

  .info-card--warning {
    background-color: var(--color-warning-bg);
    border-color: var(--color-accent);
  }

  .info-card--warning h4 { color: var(--color-accent-dark); }
  .info-card--warning p {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.7;
  }

  dl {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-2) var(--space-5);
    font-size: var(--text-sm);
  }

  dt { font-weight: 700; color: var(--color-text); white-space: nowrap; }
  dd { color: var(--color-text-muted); }
  dd a { color: var(--color-primary); }

  @media (max-width: 900px) {
    .contact-grid { grid-template-columns: 1fr; }
    .contact-info  { position: static; }
  }

  .kaart-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-6);
    flex-wrap: wrap;
    margin-bottom: var(--space-6);
  }

  .kaart-header h2 { margin-bottom: var(--space-1); }
  .kaart-header p  { color: var(--color-text-muted); font-size: var(--text-sm); margin: 0; }

  .kaart-wrapper {
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-sm);
    height: 380px;
  }

  .kaart-wrapper iframe {
    width: 100%;
    height: 100%;
    border: none;
    display: block;
  }

  .kaart-credit {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    margin-top: var(--space-2);
    margin-bottom: 0;
  }

  .kaart-credit a { color: var(--color-primary); }
</style>
