---
import PageLayout from '../layouts/PageLayout.astro';
import FAQ from '../components/FAQ.astro';
import faqData from '../data/faq.json';

const faqItems = faqData.items.map(item => ({
  question: item.vraag,
  answer:   item.antwoord,
}));
---

<PageLayout
  title="Veelgestelde vragen"
  heroTitle="Veelgestelde vragen"
  heroSubtitle="Antwoorden op de meest gestelde vragen over Pure Spirit."
  description="Veelgestelde vragen over Pure Spirit Oss: vergoedingen, groepsgrootte, begeleiding voor kinderen en meer."
>
  <section class="section">
    <div class="container container--narrow">
      <FAQ items={faqItems} />

      <div class="meer-vragen">
        <h2>Nog een vraag?</h2>
        <p class="lead">Staat jouw vraag er niet bij? Neem gerust contact op, ik help je graag verder.</p>
        <a href="/contact/" class="btn btn--primary">Stel je vraag</a>
      </div>
    </div>
  </section>
</PageLayout>

<style>
  .meer-vragen {
    margin-top: var(--space-16);
    text-align: center;
    padding: var(--space-12);
    background-color: var(--color-primary-light);
    border-radius: var(--radius-lg);
  }

  .meer-vragen h2 {
    margin-bottom: var(--space-3);
    color: var(--color-primary-dark);
  }

  .meer-vragen .lead {
    margin-bottom: var(--space-6);
    color: var(--color-text-muted);
  }
</style>
