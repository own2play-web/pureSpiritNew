---
import PageLayout from '../../layouts/PageLayout.astro';
import TestimonialCard from '../../components/TestimonialCard.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths({ paginate }) {
  const alle = await getCollection('ervaringen');
  const sorted = alle.sort((a, b) => a.data.volgorde - b.data.volgorde);
  return paginate(sorted, { pageSize: 12 });
}

const { page } = Astro.props;

type PageItem = { type: 'page'; num: number } | { type: 'ellipsis'; key: string };
const pageItems: PageItem[] = [];
for (let i = 1; i <= page.lastPage; i++) {
  const isEdge = i === 1 || i === page.lastPage;
  const isNear = Math.abs(i - page.currentPage) <= 2;
  if (isEdge || isNear) {
    pageItems.push({ type: 'page', num: i });
  } else if (pageItems[pageItems.length - 1]?.type !== 'ellipsis') {
    pageItems.push({ type: 'ellipsis', key: `ellipsis-${i}` });
  }
}
---

<PageLayout
  title={page.currentPage === 1 ? 'Ervaringen' : `Ervaringen – pagina ${page.currentPage}`}
  heroTitle="Ervaringen"
  heroSubtitle="Wat anderen zeggen over Pure Spirit. Je bent in goede handen."
  description="Ervaringen van cliënten van Pure Spirit Oss: Bachbloesemtherapie, Meditatie, Coaching en HSP-begeleiding."
>
  <section class="section">
    <div class="container">
      <div class="grid grid--2">
        {page.data.map(e => (
          <TestimonialCard
            quote={e.data.quote}
            author={e.data.auteur}
            service={e.data.dienst}
          />
        ))}
      </div>

      {page.lastPage > 1 && (
        <nav class="pagination" aria-label="Paginering">
          <div class="pagination__info">
            Pagina {page.currentPage} van {page.lastPage}
            <span class="pagination__count">({page.total} ervaringen)</span>
          </div>

          <div class="pagination__controls">
            {page.url.prev ? (
              <a href={page.url.prev} class="pagination__btn">← Vorige</a>
            ) : (
              <span class="pagination__btn pagination__btn--disabled">← Vorige</span>
            )}

            <div class="pagination__pages">
              {pageItems.map(item =>
                item.type === 'ellipsis' ? (
                  <span class="pagination__ellipsis" key={item.key}>…</span>
                ) : (
                  <a
                    href={item.num === 1 ? '/ervaringen/' : `/ervaringen/${item.num}/`}
                    class={`pagination__page${item.num === page.currentPage ? ' pagination__page--active' : ''}`}
                    aria-current={item.num === page.currentPage ? 'page' : undefined}
                  >
                    {item.num}
                  </a>
                )
              )}
            </div>

            {page.url.next ? (
              <a href={page.url.next} class="pagination__btn">Volgende →</a>
            ) : (
              <span class="pagination__btn pagination__btn--disabled">Volgende →</span>
            )}
          </div>
        </nav>
      )}

      <div style="text-align: center; margin-top: var(--space-16);">
        <p class="lead" style="margin-bottom: var(--space-6);">
          Wil jij ook ervaren wat Pure Spirit voor jou kan betekenen?
        </p>
        <a href="/contact/" class="btn btn--primary">Neem contact op</a>
      </div>
    </div>
  </section>
</PageLayout>

<style>
  .pagination {
    margin-top: var(--space-16);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
  }

  .pagination__info {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .pagination__count {
    margin-left: var(--space-1);
  }

  .pagination__controls {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-wrap: wrap;
    justify-content: center;
  }

  .pagination__btn {
    display: inline-block;
    padding: var(--space-2) var(--space-4);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-primary);
    text-decoration: none;
    transition: background-color var(--transition), border-color var(--transition);
  }

  .pagination__btn:hover {
    background-color: var(--color-primary-light);
    border-color: var(--color-primary);
  }

  .pagination__btn--disabled {
    color: var(--color-text-muted);
    pointer-events: none;
    border-color: var(--color-border);
  }

  .pagination__pages {
    display: flex;
    align-items: center;
    gap: var(--space-1);
  }

  .pagination__page {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text);
    text-decoration: none;
    transition: background-color var(--transition), border-color var(--transition), color var(--transition);
  }

  .pagination__page:hover {
    background-color: var(--color-primary-light);
    border-color: var(--color-primary);
    color: var(--color-primary-dark);
  }

  .pagination__page--active {
    background-color: var(--color-primary);
    border-color: var(--color-primary);
    color: #fff;
  }

  .pagination__page--active:hover {
    background-color: var(--color-primary-dark);
    border-color: var(--color-primary-dark);
    color: #fff;
  }

  .pagination__ellipsis {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }
</style>
