---
import agenda from '../data/agenda.json';
import nav from '../data/navigatie.json';

const openCursussen = agenda.cursussen.filter(c => c.status !== 'gesloten');
const diensten = nav.footer_diensten;

function formatDatum(iso: string) {
  return new Date(iso).toLocaleDateString('nl-NL', { day: 'numeric', month: 'long', year: 'numeric' });
}
---

<div id="inschrijven-modal" class="modal" hidden role="dialog" aria-modal="true" aria-labelledby="modal-heading" transition:persist>
  <div class="modal__backdrop"></div>
  <div class="modal__box">

    <!-- Voortgangsbalk -->
    <div class="modal__progress-bar" aria-hidden="true">
      <div class="modal__progress-fill" id="modal-progress"></div>
    </div>

    <!-- Header -->
    <div class="modal__head">
      <span class="modal__stap-label" id="modal-stap-label">Stap 1 van 3</span>
      <h2 id="modal-heading" class="modal__title">Hoe kan ik je helpen?</h2>
      <button class="modal__close" aria-label="Sluiten">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <line x1="2" y1="2" x2="16" y2="16"/><line x1="16" y1="2" x2="2" y2="16"/>
        </svg>
      </button>
    </div>

    <!-- Stap 1: Keuze -->
    <div class="modal__step" id="ms-1">
      <div class="optie-lijst">
        <button class="optie" data-keuze="cursus">
          <div class="optie__tekst">
            <strong>Cursus inschrijven</strong>
            <span>Meld je aan voor een van onze groepscursussen</span>
          </div>
          <svg class="optie__pijl" width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="4" y1="10" x2="16" y2="10"/><polyline points="11 5 16 10 11 15"/>
          </svg>
        </button>
        <button class="optie" data-keuze="sessie">
          <div class="optie__tekst">
            <strong>Individuele sessie</strong>
            <span>Plan een persoonlijk gesprek of behandeling</span>
          </div>
          <svg class="optie__pijl" width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="4" y1="10" x2="16" y2="10"/><polyline points="11 5 16 10 11 15"/>
          </svg>
        </button>
        <button class="optie" data-keuze="vraag">
          <div class="optie__tekst">
            <strong>Vraag stellen</strong>
            <span>Nog niet zeker? Ik help je graag verder</span>
          </div>
          <svg class="optie__pijl" width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="4" y1="10" x2="16" y2="10"/><polyline points="11 5 16 10 11 15"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- Stap 2a: Cursus kiezen -->
    <div class="modal__step" id="ms-2-cursus" hidden>
      <button class="modal__back">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="12" y1="8" x2="4" y2="8"/><polyline points="7 4 3 8 7 12"/>
        </svg>
        Terug
      </button>
      {openCursussen.length > 0 ? (
        <div class="cursus-lijst">
          {openCursussen.map(c => (
            <button
              class="cursus-rij"
              data-cursus={c.titel}
              data-startdatum={formatDatum(c.data[0])}
              data-status={c.status}
            >
              <div class="cursus-rij__info">
                <strong>{c.titel}</strong>
                <span>Start {formatDatum(c.data[0])} &middot; {c.tijdstip}</span>
              </div>
              <span class={`badge badge--${c.status}`}>
                {c.status === 'open' ? 'Open' : 'Op interesse'}
              </span>
            </button>
          ))}
        </div>
      ) : (
        <p class="modal__leeg">
          Er zijn momenteel geen cursussen beschikbaar.
          Neem contact op voor meer informatie.
        </p>
      )}
    </div>

    <!-- Stap 2b: Dienst kiezen -->
    <div class="modal__step" id="ms-2-sessie" hidden>
      <button class="modal__back">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="12" y1="8" x2="4" y2="8"/><polyline points="7 4 3 8 7 12"/>
        </svg>
        Terug
      </button>
      <div class="optie-lijst">
        {diensten.map(d => (
          <button class="optie" data-dienst={d.label}>
            <div class="optie__tekst">
              <strong>{d.label}</strong>
            </div>
            <svg class="optie__pijl" width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="4" y1="10" x2="16" y2="10"/><polyline points="11 5 16 10 11 15"/>
            </svg>
          </button>
        ))}
      </div>
    </div>

    <!-- Stap 3: Formulier -->
    <div class="modal__step" id="ms-3" hidden>
      <button class="modal__back">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="12" y1="8" x2="4" y2="8"/><polyline points="7 4 3 8 7 12"/>
        </svg>
        Terug
      </button>
      <form name="inschrijven" data-netlify="true" netlify-honeypot="bot-veld" class="inschrijf-form" novalidate>
        <input type="hidden" name="form-name" value="inschrijven" />
        <input type="hidden" name="keuze" id="hidden-keuze" value="" />
        <p hidden><label>Niet invullen: <input name="bot-veld" /></label></p>
        <div class="form-row">
          <div class="form-group">
            <label for="mi-naam">Naam <span aria-hidden="true">*</span></label>
            <input type="text" id="mi-naam" name="naam" required autocomplete="name" placeholder="Jouw naam" />
          </div>
          <div class="form-group">
            <label for="mi-email">E-mailadres <span aria-hidden="true">*</span></label>
            <input type="email" id="mi-email" name="email" required autocomplete="email" placeholder="jouw@email.nl" />
          </div>
        </div>
        <div class="form-group">
          <label for="mi-telefoon">Telefoonnummer</label>
          <input type="tel" id="mi-telefoon" name="telefoon" autocomplete="tel" placeholder="06 12 34 56 78" />
        </div>
        <div class="form-group">
          <label for="mi-onderwerp">Onderwerp <span aria-hidden="true">*</span></label>
          <select id="mi-onderwerp" name="onderwerp" required>
            <option value="" disabled selected>Kies een onderwerp</option>
            <option value="bachbloesemtherapie">Bachbloesemtherapie</option>
            <option value="meditatie">Meditatie</option>
            <option value="coaching">Coaching</option>
            <option value="hsp">Begeleiding HSP</option>
            <option value="persoonlijke-groei">Persoonlijke groei</option>
            <option value="priveconsult">Privéconsult</option>
            <option value="aanmelden">Aanmelden cursus / workshop</option>
            <option value="overig">Overig</option>
          </select>
        </div>
        <div class="form-group">
          <label for="mi-bericht">Bericht <span aria-hidden="true">*</span></label>
          <textarea id="mi-bericht" name="bericht" required rows="4"></textarea>
        </div>
        <p class="form-fout" id="mi-fout" hidden>Vul alle verplichte velden in.</p>
        <button type="submit" class="btn btn--primary" style="width:100%;">Verstuur aanmelding</button>
      </form>
    </div>

    <!-- Stap 4: Bevestiging -->
    <div class="modal__step modal__step--center" id="ms-4" hidden>
      <div class="bevestiging__vinkje" aria-hidden="true">
        <svg width="28" height="28" viewBox="0 0 28 28" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="5 14 11 20 23 8"/>
        </svg>
      </div>
      <h3>Bedankt voor je aanmelding</h3>
      <p>We nemen zo snel mogelijk contact met je op, uiterlijk binnen 2 werkdagen.</p>
      <button class="btn btn--primary modal__close-btn">Sluiten</button>
    </div>

  </div>
</div>

<script>
  const modal    = document.getElementById('inschrijven-modal')!;
  const backdrop = modal.querySelector('.modal__backdrop')!;
  const titleEl  = modal.querySelector('.modal__title') as HTMLElement;
  const stapLabel = modal.querySelector('#modal-stap-label') as HTMLElement;
  const progress  = modal.querySelector('#modal-progress') as HTMLElement;

  let huidigKeuze = '';
  let huidigStap  = 1;

  const titels: Record<string, string> = {
    '1':         'Hoe kan ik je helpen?',
    '2-cursus':  'Welke cursus?',
    '2-sessie':  'Welke dienst?',
    '3':         'Jouw gegevens',
    '4':         'Aanmelding ontvangen',
  };

  const stapNummers: Record<string, string> = {
    '1':        'Stap 1 van 3',
    '2-cursus': 'Stap 2 van 3',
    '2-sessie': 'Stap 2 van 3',
    '3':        'Stap 3 van 3',
    '4':        '',
  };

  const progressPct: Record<string, string> = {
    '1':        '33%',
    '2-cursus': '66%',
    '2-sessie': '66%',
    '3':        '100%',
    '4':        '100%',
  };

  function naarStap(key: string) {
    modal.querySelectorAll('.modal__step').forEach(s => (s as HTMLElement).hidden = true);
    const el = document.getElementById(`ms-${key}`);
    if (el) el.hidden = false;

    titleEl.textContent  = titels[key]     ?? '';
    stapLabel.textContent = stapNummers[key] ?? '';
    progress.style.width = progressPct[key] ?? '0%';

    (modal.querySelector('.modal__box') as HTMLElement).scrollTop = 0;
  }

  function openModal() {
    huidigKeuze = '';
    huidigStap  = 1;
    naarStap('1');
    modal.hidden = false;
    document.body.style.overflow = 'hidden';
    (modal.querySelector('.modal__close') as HTMLElement)?.focus();
  }

  function sluitModal() {
    modal.hidden = true;
    document.body.style.overflow = '';
  }

  // Trigger vanuit header
  document.addEventListener('click', e => {
    if ((e.target as HTMLElement).closest('[data-open-modal="inschrijven"]')) {
      e.preventDefault();
      openModal();
    }
  });

  modal.querySelectorAll('.modal__close, .modal__close-btn').forEach(b =>
    b.addEventListener('click', sluitModal)
  );
  backdrop.addEventListener('click', sluitModal);
  document.addEventListener('keydown', e => { if (e.key === 'Escape' && !modal.hidden) sluitModal(); });

  function setOnderwerp(value: string) {
    const sel = document.getElementById('mi-onderwerp') as HTMLSelectElement;
    if (sel) sel.value = value;
  }

  // Mapping dienst-label → onderwerp-waarde (zelfde als contactformulier)
  const dienstNaarOnderwerp: Record<string, string> = {
    'Bachbloesemtherapie': 'bachbloesemtherapie',
    'Meditatie':           'meditatie',
    'Coaching':            'coaching',
    'Begeleiding HSP':     'hsp',
    'Persoonlijke groei':  'persoonlijke-groei',
    'Privéconsult':        'priveconsult',
  };

  // Stap 1
  modal.querySelectorAll('[data-keuze]').forEach(btn => {
    btn.addEventListener('click', () => {
      huidigKeuze = (btn as HTMLElement).dataset.keuze ?? '';
      if (huidigKeuze === 'vraag') {
        (document.getElementById('mi-bericht') as HTMLTextAreaElement).value = 'Ik heb een vraag:\n\n';
        (document.getElementById('hidden-keuze') as HTMLInputElement).value = 'Vraag';
        setOnderwerp('overig');
        naarStap('3');
      } else {
        naarStap(`2-${huidigKeuze}`);
      }
    });
  });

  // Stap 2a: cursus
  modal.querySelectorAll('.cursus-rij').forEach(btn => {
    btn.addEventListener('click', () => {
      const el      = btn as HTMLElement;
      const titel   = el.dataset.cursus    ?? '';
      const datum   = el.dataset.startdatum ?? '';
      const isAnimo = el.dataset.status === 'animo';
      (document.getElementById('mi-bericht') as HTMLTextAreaElement).value = isAnimo
        ? `Ik heb interesse in de cursus "${titel}" (start ${datum}).\n\nGraag meer informatie als er voldoende animo is.`
        : `Ik wil me graag aanmelden voor de cursus "${titel}" (start ${datum}).`;
      (document.getElementById('hidden-keuze') as HTMLInputElement).value = `Cursus: ${titel}`;
      setOnderwerp('aanmelden');
      naarStap('3');
    });
  });

  // Stap 2b: dienst
  modal.querySelectorAll('[data-dienst]').forEach(btn => {
    btn.addEventListener('click', () => {
      const dienst = (btn as HTMLElement).dataset.dienst ?? '';
      (document.getElementById('mi-bericht') as HTMLTextAreaElement).value =
        `Ik wil graag een individuele sessie aanvragen voor ${dienst}.\n\n`;
      (document.getElementById('hidden-keuze') as HTMLInputElement).value = `Sessie: ${dienst}`;
      setOnderwerp(dienstNaarOnderwerp[dienst] ?? 'overig');
      naarStap('3');
    });
  });

  // Terug
  modal.querySelectorAll('.modal__back').forEach(btn => {
    btn.addEventListener('click', () => {
      if (huidigKeuze === 'vraag' || huidigKeuze === '') naarStap('1');
      else if (modal.querySelector('#ms-3:not([hidden])')) naarStap(`2-${huidigKeuze}`);
      else naarStap('1');
    });
  });

  // Formulier
  const form   = modal.querySelector('.inschrijf-form') as HTMLFormElement;
  const foutEl = document.getElementById('mi-fout') as HTMLElement;

  form?.addEventListener('submit', async e => {
    e.preventDefault();
    foutEl.hidden = true;
    const naam      = (document.getElementById('mi-naam')      as HTMLInputElement).value.trim();
    const email     = (document.getElementById('mi-email')     as HTMLInputElement).value.trim();
    const onderwerp = (document.getElementById('mi-onderwerp') as HTMLSelectElement).value;
    const bericht   = (document.getElementById('mi-bericht')   as HTMLTextAreaElement).value.trim();
    if (!naam || !email || !onderwerp || !bericht) { foutEl.hidden = false; return; }
    try {
      const res = await fetch('/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: new URLSearchParams(new FormData(form) as any).toString(),
      });
      if (res.ok) { form.reset(); naarStap('4'); }
      else {
        foutEl.textContent = 'Er is iets misgegaan. Probeer het opnieuw of neem contact op.';
        foutEl.hidden = false;
      }
    } catch {
      foutEl.textContent = 'Geen verbinding. Probeer het opnieuw.';
      foutEl.hidden = false;
    }
  });
</script>

<style>
  /* ── Overlay ─────────────────────────────────────────────── */
  .modal {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-4);
  }
  .modal[hidden] { display: none; }

  .modal__backdrop {
    position: absolute;
    inset: 0;
    background-color: rgba(26, 74, 97, 0.45);
    backdrop-filter: blur(3px);
  }

  /* ── Box ─────────────────────────────────────────────────── */
  .modal__box {
    position: relative;
    background-color: var(--color-surface);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
    width: 100%;
    max-width: 500px;
    max-height: 88vh;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
  }

  /* ── Voortgangsbalk ──────────────────────────────────────── */
  .modal__progress-bar {
    height: 3px;
    background-color: var(--color-border);
    border-radius: var(--radius-lg) var(--radius-lg) 0 0;
    overflow: hidden;
  }

  .modal__progress-fill {
    height: 100%;
    background-color: var(--color-primary);
    width: 33%;
    transition: width 300ms ease;
  }

  /* ── Header ──────────────────────────────────────────────── */
  .modal__head {
    padding: var(--space-5) var(--space-6) var(--space-4);
    border-bottom: 1px solid var(--color-border);
    position: sticky;
    top: 0;
    background-color: var(--color-surface);
    z-index: 1;
  }

  .modal__stap-label {
    display: block;
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: var(--space-1);
  }

  .modal__title {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    color: var(--color-primary-dark);
    margin: 0;
    line-height: 1.2;
    padding-right: var(--space-8);
  }

  .modal__close {
    position: absolute;
    top: var(--space-5);
    right: var(--space-5);
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-text-muted);
    padding: var(--space-1);
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color var(--transition), background-color var(--transition);
  }
  .modal__close:hover { color: var(--color-primary-dark); background-color: var(--color-primary-light); }

  /* ── Stap container ──────────────────────────────────────── */
  .modal__step[hidden] { display: none !important; }
  .modal__step { padding: var(--space-5) var(--space-6) var(--space-6); }

  .modal__step--center {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding-top: var(--space-8);
  }

  /* ── Terug knop ──────────────────────────────────────────── */
  .modal__back {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    background: none;
    border: none;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--color-text-muted);
    cursor: pointer;
    padding: 0;
    margin-bottom: var(--space-5);
    transition: color var(--transition);
  }
  .modal__back:hover { color: var(--color-primary); }

  /* ── Optie lijst (stap 1 & 2b) ───────────────────────────── */
  .optie-lijst {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .optie {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    padding: var(--space-4) var(--space-5);
    background-color: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    cursor: pointer;
    text-align: left;
    width: 100%;
    transition: border-color var(--transition), background-color var(--transition), box-shadow var(--transition);
  }
  .optie:hover {
    border-color: var(--color-primary);
    background-color: var(--color-primary-light);
    box-shadow: var(--shadow-sm);
  }

  .optie__tekst {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .optie__tekst strong {
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: 700;
    color: var(--color-text);
  }
  .optie__tekst span {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .optie__pijl {
    flex-shrink: 0;
    color: var(--color-primary);
    opacity: 0;
    transform: translateX(-4px);
    transition: opacity var(--transition), transform var(--transition);
  }
  .optie:hover .optie__pijl {
    opacity: 1;
    transform: translateX(0);
  }

  /* ── Cursus lijst (stap 2a) ──────────────────────────────── */
  .cursus-lijst {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .cursus-rij {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    padding: var(--space-4) var(--space-5);
    background-color: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    cursor: pointer;
    text-align: left;
    width: 100%;
    transition: border-color var(--transition), background-color var(--transition);
  }
  .cursus-rij:hover {
    border-color: var(--color-primary);
    background-color: var(--color-primary-light);
  }

  .cursus-rij__info {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }
  .cursus-rij__info strong {
    font-size: var(--text-base);
    font-weight: 700;
    color: var(--color-text);
  }
  .cursus-rij__info span {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .badge {
    font-size: var(--text-xs);
    font-weight: 700;
    padding: 3px var(--space-3);
    border-radius: var(--radius-full);
    white-space: nowrap;
    flex-shrink: 0;
  }
  .badge--open  { background-color: #d1f0e8; color: #0d5c42; }
  .badge--animo { background-color: #fef3c7; color: #78420a; }

  @media (prefers-color-scheme: dark) {
    .badge--open  { background-color: color-mix(in srgb, #0d5c42 18%, var(--color-surface)); color: color-mix(in srgb, #0d5c42 70%, white); }
    .badge--animo { background-color: color-mix(in srgb, #78420a 18%, var(--color-surface)); color: color-mix(in srgb, #78420a 70%, white); }
  }

  .modal__leeg {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.7;
    padding: var(--space-5);
    background-color: var(--color-primary-light);
    border-radius: var(--radius-md);
  }

  /* ── Formulier (stap 3) ──────────────────────────────────── */
  .inschrijf-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .form-group label {
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--color-text);
  }
  .form-group label span { color: var(--color-primary); }

  .form-group input,
  .form-group select,
  .form-group textarea {
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--color-text);
    background-color: var(--color-bg);
