---
import KalenderMaand from './KalenderMaand.astro';

interface Cursus {
  titel: string;
  type?: string;
  status: string;
  data: string[];
}

interface Props {
  cursussen: Cursus[];
}

const { cursussen } = Astro.props;

function slugify(s: string) {
  return s.toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g, '').replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
}

type DagInfo = { titel: string; type?: string; isStart: boolean; cursusId: string };

const dagMap: Record<string, DagInfo[]> = {};
for (const cursus of cursussen) {
  for (let i = 0; i < cursus.data.length; i++) {
    const datum = cursus.data[i];
    if (!dagMap[datum]) dagMap[datum] = [];
    dagMap[datum].push({
      titel:    cursus.titel,
      type:     cursus.type,
      isStart:  i === 0,
      cursusId: `cursus-${slugify(cursus.titel)}`,
    });
  }
}

const nu = new Date();
nu.setHours(0, 0, 0, 0);

const maandSet = new Set<string>();
for (const datum of Object.keys(dagMap)) {
  if (new Date(datum) >= nu) {
    const d = new Date(datum);
    maandSet.add(`${d.getFullYear()}-${d.getMonth()}`);
  }
}
maandSet.add(`${nu.getFullYear()}-${nu.getMonth()}`);

const kalenderMaanden = Array.from(maandSet)
  .map(s => { const [y, m] = s.split('-'); return { jaar: +y, maand: +m }; })
  .sort((a, b) => a.jaar !== b.jaar ? a.jaar - b.jaar : a.maand - b.maand);

const maandNamen = ['Januari','Februari','Maart','April','Mei','Juni',
                    'Juli','Augustus','September','Oktober','November','December'];
const dagKort    = ['Ma','Di','Wo','Do','Vr','Za','Zo'];

const typeKleur: Record<string, string> = {
  'Meditatie': '#00695c',
  'Jongeren':  '#e65100',
  'Coaching':  '#512da8',
  'HSP':       '#c62828',
  'Workshop':  '#2e7d32',
};
const typeBg: Record<string, string> = {
  'Meditatie': '#e0f2f1',
  'Jongeren':  '#fff3e0',
  'Coaching':  '#ede7f6',
  'HSP':       '#fce4ec',
  'Workshop':  '#e8f5e9',
};

function datumSleutel(jaar: number, maand: number, dag: number) {
  return `${jaar}-${String(maand + 1).padStart(2,'0')}-${String(dag).padStart(2,'0')}`;
}

const vandaagSleutel = datumSleutel(nu.getFullYear(), nu.getMonth(), nu.getDate());

const legendaTypes = Array.from(
  new Set(cursussen.map(c => c.type).filter(Boolean) as string[])
);
---

<div class="kalender-wrapper">
  <div id="kalender-grid" class:list={['kalender-grid', kalenderMaanden.length > 1 && 'kalender-grid--collapsed']}>
    {kalenderMaanden.map(({ jaar, maand }, i) => (
      <div class:list={['kalender-maand-wrap', i === 0 && 'kalender-maand-wrap--actief']} data-maand-index={i}>
        <KalenderMaand jaar={jaar} maand={maand} maandNamen={maandNamen} dagKort={dagKort} dagMap={dagMap} vandaagSleutel={vandaagSleutel} typeBg={typeBg} typeKleur={typeKleur} />
      </div>
    ))}
  </div>

  {kalenderMaanden.length > 1 && (
    <div class="kalender-mobiel-nav">
      <button type="button" id="kalender-vorige" class="kalender-nav-btn" aria-label="Vorige maand" disabled>
        <svg width="18" height="18" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="10 3 5 8 10 13"/></svg>
      </button>
      <span id="kalender-mobiel-label" class="kalender-mobiel-label" aria-live="polite"></span>
      <button type="button" id="kalender-volgende" class="kalender-nav-btn" aria-label="Volgende maand">
        <svg width="18" height="18" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 3 11 8 6 13"/></svg>
      </button>
    </div>
  )}

  {kalenderMaanden.length > 1 && (
    <button type="button" class="btn btn--outline kalender-toggle" id="kalender-toggle" aria-expanded="false" aria-controls="kalender-grid">
      Toon meer maanden
    </button>
  )}

  <div class="kalender-legenda-rij">
    {legendaTypes.length > 0 && (
      <ul class="kalender-legenda">
        {legendaTypes.map(type => (
          <li>
            <span class="legenda-kleur" style={`--leg-bg:${typeBg[type]};--leg-kleur:${typeKleur[type]}`}>{type.slice(0,1)}</span>
            {type}
          </li>
        ))}
      </ul>
    )}
    <ul class="kalender-legenda">
      <li><span class="legenda-start">9</span> Startdatum</li>
      <li><span class="legenda-vervolg">9</span> Vervolgles</li>
    </ul>
  </div>
</div>

<div id="kal-tooltip" class="kal-tooltip" role="tooltip"></div>

<script>
  const tooltip  = document.getElementById('kal-tooltip') as HTMLDivElement;
  let hideTimer: ReturnType<typeof setTimeout> | null = null;

  function toon(knop: HTMLButtonElement) {
    if (hideTimer) { clearTimeout(hideTimer); hideTimer = null; }

    const info = knop.dataset.tooltip ?? '';
    tooltip.innerHTML = info
      .split('\n')
      .map(r => `<span>${r}</span>`)
      .join('');
    tooltip.classList.add('kal-tooltip--zichtbaar');

    // Positioneer onder de knop
    const r  = knop.getBoundingClientRect();
    const tw = tooltip.offsetWidth;
    let left = r.left + window.scrollX + r.width / 2 - tw / 2;
    left = Math.max(8, Math.min(left, window.innerWidth - tw - 8));
    tooltip.style.top  = `${r.bottom + window.scrollY + 6}px`;
    tooltip.style.left = `${left}px`;
  }

  function verberg(vertraging = 0) {
    if (hideTimer) clearTimeout(hideTimer);
    hideTimer = setTimeout(() => {
      tooltip.classList.remove('kal-tooltip--zichtbaar');
    }, vertraging);
  }

  const toggleBtn = document.getElementById('kalender-toggle') as HTMLButtonElement | null;
  const grid      = document.getElementById('kalender-grid') as HTMLElement | null;
  const labelMeer = toggleBtn?.textContent ?? '';

  toggleBtn?.addEventListener('click', () => {
    const open = toggleBtn.getAttribute('aria-expanded') === 'true';
    grid?.classList.toggle('kalender-grid--collapsed', open);
    toggleBtn.setAttribute('aria-expanded', String(!open));
    toggleBtn.textContent = open ? labelMeer : 'Toon minder maanden';
  });

  // Mobiel: 1 maand tegelijk met vorige/volgende i.p.v. de "toon meer" grid
  const maandWraps = Array.from(document.querySelectorAll<HTMLElement>('.kalender-maand-wrap'));
  const vorigeBtn   = document.getElementById('kalender-vorige')   as HTMLButtonElement | null;
  const volgendeBtn = document.getElementById('kalender-volgende') as HTMLButtonElement | null;
  const mobielLabel = document.getElementById('kalender-mobiel-label') as HTMLElement | null;
  let mobielIndex = maandWraps.findIndex(w => w.classList.contains('kalender-maand-wrap--actief'));
  if (mobielIndex < 0) mobielIndex = 0;

  function updateMobielNav() {
    maandWraps.forEach((w, i) => w.classList.toggle('kalender-maand-wrap--actief', i === mobielIndex));
    if (vorigeBtn)   vorigeBtn.disabled   = mobielIndex === 0;
    if (volgendeBtn) volgendeBtn.disabled = mobielIndex === maandWraps.length - 1;
    if (mobielLabel) {
      const titel = maandWraps[mobielIndex]?.querySelector('.kalender-maand__titel')?.textContent ?? '';
      mobielLabel.textContent = titel;
    }
  }

  vorigeBtn?.addEventListener('click', () => {
    if (mobielIndex > 0) { mobielIndex--; updateMobielNav(); }
  });
  volgendeBtn?.addEventListener('click', () => {
    if (mobielIndex < maandWraps.length - 1) { mobielIndex++; updateMobielNav(); }
  });

  if (maandWraps.length > 0) updateMobielNav();

  document.querySelectorAll<HTMLButtonElement>('[data-cursus-id]').forEach(knop => {
    knop.addEventListener('mouseenter', () => toon(knop));
    knop.addEventListener('mouseleave', () => verberg(120));

    knop.addEventListener('click', () => {
      verberg(0);
      const id = knop.dataset.cursusId;
      if (!id) return;
      const kaart = document.getElementById(id);
      if (!kaart) return;
      kaart.scrollIntoView({ behavior: 'smooth', block: 'center' });
      kaart.classList.add('cursus-kaart--highlight');
      setTimeout(() => kaart.classList.remove('cursus-kaart--highlight'), 1400);
    });
  });

  tooltip.addEventListener('mouseenter', () => {
    if (hideTimer) { clearTimeout(hideTimer); hideTimer = null; }
  });
  tooltip.addEventListener('mouseleave', () => verberg(80));
</script>

<style>
  .kalender-wrapper {
    margin-bottom: var(--space-12);
  }

  .kalender-grid {
    display: grid;
    grid-template-columns: repeat(1, 1fr);
    gap: var(--space-5);
    margin-bottom: var(--space-4);
  }

  @media (min-width: 640px) {
    .kalender-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 1024px) {
    .kalender-grid { grid-template-columns: repeat(4, 1fr); }
  }

  /* Tablet/desktop: toon alleen de eerste rij; aantal kolommen (en dus
     verborgen kaarten) verschilt per breakpoint, vandaar exclusieve ranges
     per media query. :global() nodig omdat de kaarten worden gerenderd
     door het KalenderMaand-subcomponent en dus een ander Astro-scope-
     attribuut hebben dan dit component. */
  @media (min-width: 640px) and (max-width: 1023px) {
    :global(.kalender-grid--collapsed > .kalender-maand-wrap:nth-child(n + 3)) { display: none; }
  }

  @media (min-width: 1024px) {
    :global(.kalender-grid--collapsed > .kalender-maand-wrap:nth-child(n + 5)) { display: none; }
  }

  /* Mobiel: 1 maand tegelijk via vorige/volgende-knoppen i.p.v. een grid */
  @media (max-width: 639px) {
    .kalender-maand-wrap { display: none; }
    .kalender-maand-wrap--actief { display: block; }
    .kalender-toggle { display: none; }
  }

  .kalender-mobiel-nav {
    display: none;
  }

  @media (max-width: 639px) {
    .kalender-mobiel-nav {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: var(--space-5);
      margin-bottom: var(--space-6);
    }
  }

  .kalender-nav-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    flex-shrink: 0;
    border-radius: var(--radius-full);
    border: 1px solid var(--color-border-strong);
    background-color: var(--color-surface);
    color: var(--color-primary);
    cursor: pointer;
    transition: background-color var(--transition), color var(--transition), opacity var(--transition);
  }

  .kalender-nav-btn:hover:not(:disabled) {
    background-color: var(--color-primary);
    color: #fff;
  }

  .kalender-nav-btn:disabled {
    opacity: 0.35;
    cursor: default;
  }

  .kalender-mobiel-label {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--color-primary-dark);
    text-align: center;
    min-width: 140px;
  }

  .kalender-toggle {
    display: flex;
    margin: 0 auto var(--space-6);
    font-size: var(--text-sm);
    padding: var(--space-2) var(--space-5);
  }

  /* Tooltip */
  .kal-tooltip {
    position: absolute;
    z-index: 200;
    background-color: var(--color-footer-bg);
    color: var(--color-text-light);
    border-radius: var(--radius-md);
    padding: var(--space-3) var(--space-4);
    font-family: var(--font-body);
    font-size: var(--text-xs);
    line-height: 1.8;
    display: none;
    flex-direction: column;
    gap: 2px;
    max-width: 240px;
    box-shadow: var(--shadow-md);
    pointer-events: none;
  }

  .kal-tooltip--zichtbaar {
    display: flex;
    pointer-events: auto;
  }

  /* Legenda */
  .kalender-legenda-rij {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-6);
  }

  .kalender-legenda {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .kalender-legenda li {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-body);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  .legenda-kleur {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    border-radius: var(--radius-sm);
    font-size: 0.6rem;
    font-weight: 700;
    background-color: var(--leg-bg);
    color: var(--leg-kleur);
  }

  @media (prefers-color-scheme: dark) {
    .legenda-kleur {
      background-color: color-mix(in srgb, var(--leg-bg) 25%, var(--color-surface));
      color: color-mix(in srgb, var(--leg-kleur) 70%, white);
    }
  }

  .legenda-start {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    border-radius: var(--radius-sm);
    font-size: var(--text-xs);
    font-weight: 700;
    background-color: var(--color-primary-light);
    color: var(--color-primary-dark);
  }

  .legenda-vervolg {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    font-size: var(--text-xs);
    color: var(--color-text);
  }

  .legenda-vervolg::after {
    content: '';
    position: absolute;
    bottom: 1px;
    left: 50%;
    transform: translateX(-50%);
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background-color: var(--color-primary);
  }
</style>
