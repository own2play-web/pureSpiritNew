---
import KalenderMaand from './KalenderMaand.astro';

interface Cursus {
  titel: string;
  type?: string;
  status: string;
  data: string[];
}

interface Props {
  cursussen: Cursus[];
}

const { cursussen } = Astro.props;

function slugify(s: string) {
  return s.toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g, '').replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
}

type DagInfo = { titel: string; type?: string; isStart: boolean; cursusId: string };

const dagMap: Record<string, DagInfo[]> = {};
for (const cursus of cursussen) {
  for (let i = 0; i < cursus.data.length; i++) {
    const datum = cursus.data[i];
    if (!dagMap[datum]) dagMap[datum] = [];
    dagMap[datum].push({
      titel:    cursus.titel,
      type:     cursus.type,
      isStart:  i === 0,
      cursusId: `cursus-${slugify(cursus.titel)}`,
    });
  }
}

const nu = new Date();
nu.setHours(0, 0, 0, 0);

const maandSet = new Set<string>();
for (const datum of Object.keys(dagMap)) {
  if (new Date(datum) >= nu) {
    const d = new Date(datum);
    maandSet.add(`${d.getFullYear()}-${d.getMonth()}`);
  }
}
maandSet.add(`${nu.getFullYear()}-${nu.getMonth()}`);

const kalenderMaanden = Array.from(maandSet)
  .map(s => { const [y, m] = s.split('-'); return { jaar: +y, maand: +m }; })
  .sort((a, b) => a.jaar !== b.jaar ? a.jaar - b.jaar : a.maand - b.maand);

const maandNamen = ['Januari','Februari','Maart','April','Mei','Juni',
                    'Juli','Augustus','September','Oktober','November','December'];
const dagKort    = ['Ma','Di','Wo','Do','Vr','Za','Zo'];

const typeKleur: Record<string, string> = {
  'Meditatie': '#00695c',
  'Jongeren':  '#e65100',
  'Coaching':  '#512da8',
  'HSP':       '#c62828',
  'Workshop':  '#2e7d32',
};
const typeBg: Record<string, string> = {
  'Meditatie': '#e0f2f1',
  'Jongeren':  '#fff3e0',
  'Coaching':  '#ede7f6',
  'HSP':       '#fce4ec',
  'Workshop':  '#e8f5e9',
};

function datumSleutel(jaar: number, maand: number, dag: number) {
  return `${jaar}-${String(maand + 1).padStart(2,'0')}-${String(dag).padStart(2,'0')}`;
}

const vandaagSleutel = datumSleutel(nu.getFullYear(), nu.getMonth(), nu.getDate());

const legendaTypes = Array.from(
  new Set(cursussen.map(c => c.type).filter(Boolean) as string[])
);

const ZICHTBARE_MAANDEN = 3;
const directZichtbaar = kalenderMaanden.slice(0, ZICHTBARE_MAANDEN);
const extraMaanden     = kalenderMaanden.slice(ZICHTBARE_MAANDEN);
---

<div class="kalender-wrapper">
  <div class="kalender-grid">
    {directZichtbaar.map(({ jaar, maand }) => (
      <KalenderMaand jaar={jaar} maand={maand} maandNamen={maandNamen} dagKort={dagKort} dagMap={dagMap} vandaagSleutel={vandaagSleutel} typeBg={typeBg} typeKleur={typeKleur} />
    ))}
  </div>

  {extraMaanden.length > 0 && (
    <>
      <div class="kalender-grid" id="kalender-extra" hidden>
        {extraMaanden.map(({ jaar, maand }) => (
          <KalenderMaand jaar={jaar} maand={maand} maandNamen={maandNamen} dagKort={dagKort} dagMap={dagMap} vandaagSleutel={vandaagSleutel} typeBg={typeBg} typeKleur={typeKleur} />
        ))}
      </div>
      <button type="button" class="btn btn--outline kalender-toggle" id="kalender-toggle" aria-expanded="false" aria-controls="kalender-extra">
        Toon {extraMaanden.length} {extraMaanden.length === 1 ? 'maand' : 'maanden'} meer
      </button>
    </>
  )}

  <div class="kalender-legenda-rij">
    {legendaTypes.length > 0 && (
      <ul class="kalender-legenda">
        {legendaTypes.map(type => (
          <li>
            <span class="legenda-kleur" style={`--leg-bg:${typeBg[type]};--leg-kleur:${typeKleur[type]}`}>{type.slice(0,1)}</span>
            {type}
          </li>
        ))}
      </ul>
    )}
    <ul class="kalender-legenda">
      <li><span class="legenda-start">9</span> Startdatum</li>
      <li><span class="legenda-vervolg">9</span> Vervolgles</li>
    </ul>
  </div>
</div>

<div id="kal-tooltip" class="kal-tooltip" role="tooltip"></div>

<script>
  const tooltip  = document.getElementById('kal-tooltip') as HTMLDivElement;
  let hideTimer: ReturnType<typeof setTimeout> | null = null;

  function toon(knop: HTMLButtonElement) {
    if (hideTimer) { clearTimeout(hideTimer); hideTimer = null; }

    const info = knop.dataset.tooltip ?? '';
    tooltip.innerHTML = info
      .split('\n')
      .map(r => `<span>${r}</span>`)
      .join('');
    tooltip.classList.add('kal-tooltip--zichtbaar');

    // Positioneer onder de knop
    const r  = knop.getBoundingClientRect();
    const tw = tooltip.offsetWidth;
    let left = r.left + window.scrollX + r.width / 2 - tw / 2;
    left = Math.max(8, Math.min(left, window.innerWidth - tw - 8));
    tooltip.style.top  = `${r.bottom + window.scrollY + 6}px`;
    tooltip.style.left = `${left}px`;
  }

  function verberg(vertraging = 0) {
    if (hideTimer) clearTimeout(hideTimer);
    hideTimer = setTimeout(() => {
      tooltip.classList.remove('kal-tooltip--zichtbaar');
    }, vertraging);
  }

  const toggleBtn    = document.getElementById('kalender-toggle') as HTMLButtonElement | null;
  const extraMaanden = document.getElementById('kalender-extra') as HTMLElement | null;
  const labelMeer    = toggleBtn?.textContent ?? '';

  toggleBtn?.addEventListener('click', () => {
    const open = toggleBtn.getAttribute('aria-expanded') === 'true';
    if (extraMaanden) extraMaanden.hidden = open;
    toggleBtn.setAttribute('aria-expanded', String(!open));
    toggleBtn.textContent = open ? labelMeer : 'Toon minder maanden';
  });

  document.querySelectorAll<HTMLButtonElement>('[data-cursus-id]').forEach(knop => {
    knop.addEventListener('mouseenter', () => toon(knop));
    knop.addEventListener('mouseleave', () => verberg(120));

    knop.addEventListener('click', () => {
      verberg(0);
      const id = knop.dataset.cursusId;
      if (!id) return;
      const kaart = document.getElementById(id);
      if (!kaart) return;
      kaart.scrollIntoView({ behavior: 'smooth', block: 'center' });
      kaart.classList.add('cursus-kaart--highlight');
      setTimeout(() => kaart.classList.remove('cursus-kaart--highlight'), 1400);
    });
  });

  tooltip.addEventListener('mouseenter', () => {
    if (hideTimer) { clearTimeout(hideTimer); hideTimer = null; }
  });
  tooltip.addEventListener('mouseleave', () => verberg(80));
</script>

<style>
  .kalender-wrapper {
    margin-bottom: var(--space-12);
  }

  .kalender-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: var(--space-5);
    margin-bottom: var(--space-4);
  }

  .kalender-toggle {
    display: flex;
    margin: 0 auto var(--space-6);
    font-size: var(--text-sm);
    padding: var(--space-2) var(--space-5);
  }

  /* Tooltip */
  .kal-tooltip {
    position: absolute;
    z-index: 200;
    background-color: var(--color-text);
    color: var(--color-text-light);
    border-radius: var(--radius-md);
    padding: var(--space-3) var(--space-4);
    font-family: var(--font-body);
    font-size: var(--text-xs);
    line-height: 1.8;
    display: none;
    flex-direction: column;
    gap: 2px;
    max-width: 240px;
    box-shadow: var(--shadow-md);
    pointer-events: none;
  }

  .kal-tooltip--zichtbaar {
    display: flex;
    pointer-events: auto;
  }

  /* Legenda */
  .kalender-legenda-rij {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-6);
  }

  .kalender-legenda {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .kalender-legenda li {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-body);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  .legenda-kleur {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    border-radius: var(--radius-sm);
    font-size: 0.6rem;
    font-weight: 700;
    background-color: var(--leg-bg);
    color: var(--leg-kleur);
  }

  @media (prefers-color-scheme: dark) {
    .legenda-kleur {
      background-color: color-mix(in srgb, var(--leg-bg) 25%, var(--color-surface));
      color: color-mix(in srgb, var(--leg-kleur) 70%, white);
    }
  }

  .legenda-start {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    border-radius: var(--radius-sm);
    font-size: var(--text-xs);
    font-weight: 700;
    background-color: var(--color-primary-light);
    color: var(--color-primary-dark);
  }

  .legenda-vervolg {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    font-size: var(--text-xs);
    color: var(--color-text);
  }

  .legenda-vervolg::after {
    content: '';
    position: absolute;
    bottom: 1px;
    left: 50%;
    transform: translateX(-50%);
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background-color: var(--color-primary);
  }
</style>
