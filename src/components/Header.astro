---
const navLinks = [
  { label: 'Diensten',          href: '/diensten/',
    children: [
      { label: 'Bachbloesemtherapie', href: '/diensten/bachbloesemtherapie/' },
      { label: 'Meditatie',           href: '/diensten/meditatie/' },
      { label: 'Coaching',            href: '/diensten/coaching/' },
      { label: 'Begeleiding HSP',     href: '/diensten/begeleiding-hsp/' },
      { label: 'Persoonlijke groei',  href: '/diensten/persoonlijke-groei/' },
      { label: 'Privéconsult',        href: '/diensten/prive-consult/' },
    ]
  },
  { label: 'Over mij',   href: '/over/' },
  { label: 'Tarieven',   href: '/tarieven/' },
  { label: 'Nieuws',     href: '/nieuws/' },
  { label: 'Agenda',     href: '/agenda/' },
  { label: 'Ervaringen', href: '/ervaringen/' },
  { label: 'Contact',    href: '/contact/' },
];

import nav from '../data/navigatie.json';
const currentPath = Astro.url.pathname;
---

<header class="header">
  <div class="container header__inner">
    <a href="/" class="header__logo" aria-label="Pure Spirit – naar homepagina">
      <img src="/uploads/pure-spirit-logo-95px-hoog.png" alt="Pure Spirit Oss" class="logo-img" width="220" height="95" />
    </a>

    <button class="header__toggle" aria-controls="main-nav" aria-expanded="false" aria-label="Menu openen">
      <span></span><span></span><span></span>
    </button>

    <nav id="main-nav" class="header__nav" aria-label="Hoofdnavigatie">
      <ul class="nav-list">
        {navLinks.map(link => (
          <li class:list={['nav-item', link.children && 'nav-item--has-children']}>
            <a
              href={link.href}
              class:list={['nav-link', currentPath === link.href && 'nav-link--active']}
            >
              {link.label}
              {link.children && <span class="nav-arrow" aria-hidden="true">▾</span>}
            </a>
            {link.children && (
              <button class="nav-toggle" aria-expanded="false" aria-label={`${link.label} submenu uitklappen`}>
                <span class="nav-arrow" aria-hidden="true">▾</span>
              </button>
            )}
            {link.children && (
              <ul class="nav-dropdown">
                {link.children.map(child => (
                  <li>
                    <a
                      href={child.href}
                      class:list={['nav-dropdown__link', currentPath === child.href && 'nav-link--active']}
                    >
                      {child.label}
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </li>
        ))}
        <li class="nav-item nav-item--cta">
          <a href={nav.header_cta_url} class="btn btn--primary header__cta" data-open-modal="inschrijven">{nav.header_cta_label}</a>
        </li>
      </ul>
    </nav>
  </div>
</header>

<script>
  function initMenu() {
    const toggle = document.querySelector('.header__toggle') as HTMLButtonElement;
    const nav    = document.querySelector('#main-nav') as HTMLElement;

    if (!toggle || !nav) return;

    // Remove old listener by replacing the element clone, then re-add
    const fresh = toggle.cloneNode(true) as HTMLButtonElement;
    toggle.replaceWith(fresh);

    fresh.addEventListener('click', () => {
      const open = fresh.getAttribute('aria-expanded') === 'true';
      fresh.setAttribute('aria-expanded', String(!open));
      nav.classList.toggle('header__nav--open', !open);
    });

    // Mobile: submenu toggle
    nav.querySelectorAll('.nav-toggle').forEach(btn => {
      btn.addEventListener('click', () => {
        const item = btn.closest('.nav-item') as HTMLElement;
        const isOpen = item.classList.contains('nav-item--open');
        // Sluit alle andere open submenus
        nav.querySelectorAll('.nav-item--open').forEach(el => {
          el.classList.remove('nav-item--open');
          el.querySelector('.nav-toggle')?.setAttribute('aria-expanded', 'false');
        });
        if (!isOpen) {
          item.classList.add('nav-item--open');
          btn.setAttribute('aria-expanded', 'true');
        }
      });
    });

    // Sluit menu bij klik op een link (mobiel)
    nav.querySelectorAll('.nav-dropdown__link').forEach(link => {
      link.addEventListener('click', () => {
        fresh.setAttribute('aria-expanded', 'false');
        nav.classList.remove('header__nav--open');
      });
    });

    // Sluit menu bij klik op een top-level link zonder children
    nav.querySelectorAll('.nav-link').forEach(link => {
      const item = link.closest('.nav-item');
      if (!item?.classList.contains('nav-item--has-children')) {
        link.addEventListener('click', () => {
          fresh.setAttribute('aria-expanded', 'false');
          nav.classList.remove('header__nav--open');
        });
      }
    });
  }

  document.addEventListener('astro:page-load', initMenu);
</script>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
    box-shadow: var(--shadow-sm);
  }

  .header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 72px;
  }

  .header__logo {
    display: flex;
    align-items: center;
    text-decoration: none;
    padding-right: var(--space-6);
    border-right: 1px solid var(--color-border);
    flex-shrink: 0;
  }

  .logo-img {
    height: 64px;
    width: auto;
  }

  .header__nav {
    display: flex;
    align-items: center;
    gap: var(--space-8);
    align-self: stretch;
  }

  .nav-list {
    display: flex;
    list-style: none;
    gap: var(--space-1);
    padding: 0;
    margin: 0;
  }

  .nav-item {
    position: relative;
  }

  .nav-link {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    padding: var(--space-2) var(--space-3);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--color-text);
    text-decoration: none;
    border-radius: var(--radius-sm);
    transition: color var(--transition), background-color var(--transition);
  }

  .nav-link:hover,
  .nav-link--active {
    color: var(--color-primary);
    background-color: var(--color-primary-light);
  }

  .nav-arrow {
    font-size: 0.65em;
    transition: transform var(--transition);
  }

  .nav-item--has-children:hover .nav-arrow {
    transform: rotate(180deg);
  }

  .nav-dropdown {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    padding-top: 8px;
    min-width: 220px;
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-md);
    list-style: none;
    padding: var(--space-2) 0;
    margin: 0;
    z-index: 10;
  }

  .nav-item--has-children:hover .nav-dropdown {
    display: block;
  }

  .nav-dropdown__link {
    display: block;
    padding: var(--space-2) var(--space-4);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-text);
    text-decoration: none;
    transition: background-color var(--transition), color var(--transition);
  }

  .nav-dropdown__link:hover,
  .nav-dropdown__link.nav-link--active {
    background-color: var(--color-primary-light);
    color: var(--color-primary);
  }

  .header__toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: var(--space-2);
  }

  .header__toggle span {
    display: block;
    width: 24px;
    height: 2px;
    background-color: var(--color-text);
    border-radius: 2px;
    transition: transform var(--transition), opacity var(--transition);
  }

  .nav-toggle { display: none; }

  .nav-item--cta {
    display: flex;
    align-items: center;
    padding-left: var(--space-4);
  }

  .header__cta {
    font-size: var(--text-sm);
    padding: calc(var(--space-2) - 2px) var(--space-5);
  }

  @media (max-width: 900px) {
    .header__toggle { display: flex; }

    .nav-item--cta {
      padding-left: 0;
      padding-top: var(--space-4);
      border-top: 1px solid var(--color-border);
      margin-top: var(--space-2);
      width: 100%;
    }

    .header__cta {
      display: block;
      width: 100%;
      text-align: center;
      font-size: var(--text-base);
    }

    .header__inner { position: relative; justify-content: center; }
    .header__logo  { padding-right: 0; border-right: none; }
    .header__toggle { position: absolute; right: 0; }

    .header__nav {
      display: none;
      position: absolute;
      top: 72px;
      left: 0;
      right: 0;
      background-color: var(--color-surface);
      border-bottom: 1px solid var(--color-border);
      box-shadow: var(--shadow-md);
      padding: var(--space-4) var(--space-6);
      flex-direction: column;
      align-items: flex-start;
    }

    .header__nav--open { display: flex; }

    .nav-list {
      flex-direction: column;
      width: 100%;
      gap: 0;
    }

    .nav-item--has-children .nav-link .nav-arrow { display: none; }

    .nav-link {
      padding: var(--space-3) var(--space-2);
      font-size: var(--text-base);
      width: 100%;
    }

    /* Submenu toggle knop op mobiel */
    .nav-item--has-children {
      position: relative;
    }

    .nav-link {
      padding-right: var(--space-12);
    }

    .nav-toggle {
      display: flex;
      align-items: center;
      justify-content: center;
      position: absolute;
      right: 0;
      top: 0;
      width: 48px;
      height: 48px;
      background: none;
      border: none;
      cursor: pointer;
      color: var(--color-text-muted);
      padding: 0;
    }

    .nav-toggle .nav-arrow {
      font-size: 1em;
      transition: transform var(--transition);
    }

    .nav-item--open > .nav-toggle .nav-arrow {
      transform: rotate(180deg);
    }

    /* Dropdown inline op mobiel */
    .nav-dropdown {
      display: none;
      position: static;
      box-shadow: none;
      border: none;
      border-left: 3px solid var(--color-primary-light);
      border-radius: 0;
      background: none;
      padding: var(--space-1) 0 var(--space-2) var(--space-4);
      margin: 0;
    }

    .nav-item--open > .nav-dropdown {
      display: block;
    }

    .nav-dropdown__link {
      padding: var(--space-2) var(--space-2);
      font-size: var(--text-sm);
    }
  }
</style>
