---
const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer__grid">
    <div class="footer__brand">
      <a href="/" class="footer__logo">
        <img src="/uploads/logo.png" alt="Pure Spirit Oss" class="footer__logo-img" />
      </a>
      <p>
        Bachbloesemtherapie, Meditatie, Coaching,<br />
        Begeleiding HSP en Persoonlijke Ontwikkeling.
      </p>
      <p class="footer__motto">
        <em>Zuiverheid · Eenvoud · Kracht</em>
      </p>
    </div>

    <div class="footer__col">
      <h4>Diensten</h4>
      <ul>
        <li><a href="/bachbloesemtherapie/">Bachbloesemtherapie</a></li>
        <li><a href="/meditatie/">Meditatie</a></li>
        <li><a href="/coaching/">Coaching</a></li>
        <li><a href="/begeleiding-hsp/">Begeleiding HSP</a></li>
        <li><a href="/persoonlijke-groei/">Persoonlijke groei</a></li>
      </ul>
    </div>

    <div class="footer__col">
      <h4>Navigatie</h4>
      <ul>
        <li><a href="/tarieven/">Tarieven</a></li>
        <li><a href="/nieuws/">Nieuws</a></li>
        <li><a href="/ervaringen/">Ervaringen</a></li>
        <li><a href="/contact/">Contact</a></li>
        <li><a href="/contact/">Aanmelden</a></li>
      </ul>
    </div>

    <div class="footer__col">
      <h4>Contact</h4>
      <address>
        <p>Beethovengaarde 90<br />5344 CK Oss</p>
        <p><a href="tel:0412692162">0412 69 21 62</a></p>
        <p><a href="mailto:info@purespirit-oss.nl">info@purespirit-oss.nl</a></p>
      </address>
      <p class="footer__hours">
        <strong>Openingstijden</strong><br />
        Ma – Vr: 9:00 – 21:30<br />
        Za – Zo: Gesloten<br />
        <em>(op afspraak)</em>
      </p>
    </div>
  </div>

  <div class="footer__bottom">
    <div class="container footer__bottom-inner">
      <p>&copy; {currentYear} Pure Spirit Oss &nbsp;·&nbsp; KVK: 53415000</p>
      <p>
        <a href="/privacy/">Privacybeleid</a>
      </p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--color-primary-dark);
    color: rgba(255,255,255,0.85);
    margin-top: var(--space-20);
  }

  .footer__grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1.5fr;
    gap: var(--space-12);
    padding-block: var(--space-16);
  }

  .footer__logo {
    display: inline-block;
    text-decoration: none;
    margin-bottom: var(--space-4);
  }

  .footer__logo-img {
    height: 70px;
    width: auto;
    filter: brightness(0) invert(1);
    opacity: 0.9;
  }

  .footer__brand p {
    font-size: var(--text-sm);
    color: rgba(255,255,255,0.75);
    line-height: 1.7;
    margin-bottom: var(--space-3);
  }

  .footer__motto {
    color: var(--color-accent) !important;
    font-family: var(--font-heading);
  }

  .footer__col h4 {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.5);
    margin-bottom: var(--space-4);
  }

  .footer__col ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .footer__col a,
  .footer address a {
    color: rgba(255,255,255,0.8);
    text-decoration: none;
    font-size: var(--text-sm);
    transition: color var(--transition);
  }

  .footer__col a:hover,
  .footer address a:hover {
    color: var(--color-accent);
  }

  address {
    font-style: normal;
  }

  address p {
    font-size: var(--text-sm);
    color: rgba(255,255,255,0.8);
    line-height: 1.6;
    margin-bottom: var(--space-2);
  }

  .footer__hours {
    font-size: var(--text-sm);
    color: rgba(255,255,255,0.7);
    line-height: 1.7;
    margin-top: var(--space-4);
  }

  .footer__bottom {
    border-top: 1px solid rgba(255,255,255,0.1);
  }

  .footer__bottom-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-block: var(--space-4);
    font-size: var(--text-sm);
    color: rgba(255,255,255,0.5);
  }

  .footer__bottom a {
    color: rgba(255,255,255,0.5);
    text-decoration: none;
    transition: color var(--transition);
  }

  .footer__bottom a:hover {
    color: rgba(255,255,255,0.9);
  }

  @media (max-width: 900px) {
    .footer__grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-8);
    }
  }

  @media (max-width: 640px) {
    .footer__grid {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }

    .footer__bottom-inner {
      flex-direction: column;
      gap: var(--space-2);
      text-align: center;
    }
  }
</style>
