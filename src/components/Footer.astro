---
import site from '../data/site.json';
import nav from '../data/navigatie.json';
const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer__grid">
    <div class="footer__brand">
      <a href="/" class="footer__logo">
        <img src="/uploads/pure-spirit-logo-95px-hoog.png" alt="Pure Spirit Oss" class="footer__logo-img" width="220" height="95" />
      </a>
      <p>{nav.footer_beschrijving}</p>
      <p class="footer__motto">
        <em>{nav.footer_motto}</em>
      </p>
    </div>

    <div class="footer__col">
      <h3>Diensten</h3>
      <ul>
        {nav.footer_diensten.map(item => (
          <li><a href={item.href}>{item.label}</a></li>
        ))}
      </ul>
    </div>

    <div class="footer__col">
      <h3>Navigatie</h3>
      <ul>
        {nav.footer_navigatie.map(item => (
          <li><a href={item.href}>{item.label}</a></li>
        ))}
      </ul>
    </div>

    <div class="footer__col">
      <h3>Contact</h3>
      <address>
        <p>{site.adres}<br />{site.postcode} {site.stad}</p>
        <p><a href={`tel:${site.telefoon.replace(/\s/g,'')}`}>{site.telefoon}</a></p>
        <p><a href={`mailto:${site.email}`}>{site.email}</a></p>
      </address>
      <p class="footer__hours">
        <strong>Openingstijden</strong><br />
        {site.openingstijden.map(o => (
          <>{o.dag}: {o.tijd}<br /></>
        ))}
        <em>({site.openingstijden_opmerking})</em>
      </p>
    </div>
  </div>

  <div class="footer__bottom">
    <div class="container footer__bottom-inner">
      <p>&copy; {currentYear} {site.naam} {site.stad} &nbsp;·&nbsp; KVK: {site.kvk}</p>
      <div class="footer__bottom-links">
        <a href="/privacy/">Privacybeleid</a>
        {site.facebook && (
          <a href={site.facebook} target="_blank" rel="noopener noreferrer" aria-label="Pure Spirit op Facebook">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
            </svg>
            Facebook
          </a>
        )}
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--color-primary-dark);
    color: rgba(255,255,255,0.85);
  }

  .footer__grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1.5fr;
    gap: var(--space-12);
    padding-block: var(--space-16);
  }

  .footer__logo {
    display: inline-block;
    text-decoration: none;
    margin-bottom: var(--space-4);
  }

  .footer__logo-img {
    height: 70px;
    width: auto;
    filter: brightness(0) invert(1);
    opacity: 0.9;
  }

  .footer__brand p {
    font-size: var(--text-sm);
    color: rgba(255,255,255,0.75);
    line-height: 1.7;
    margin-bottom: var(--space-3);
  }

  .footer__motto {
    color: var(--color-accent) !important;
    font-family: var(--font-heading);
  }

  .footer__col h3 {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.75);
    margin-bottom: var(--space-4);
  }

  .footer__col ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .footer__col a,
  .footer address a {
    color: rgba(255,255,255,0.8);
    text-decoration: none;
    font-size: var(--text-sm);
    transition: color var(--transition);
  }

  .footer__col a:hover,
  .footer address a:hover {
    color: var(--color-accent);
  }

  address {
    font-style: normal;
  }

  address p {
    font-size: var(--text-sm);
    color: rgba(255,255,255,0.8);
    line-height: 1.6;
    margin-bottom: var(--space-2);
  }

  .footer__hours {
    font-size: var(--text-sm);
    color: rgba(255,255,255,0.7);
    line-height: 1.7;
    margin-top: var(--space-4);
  }

  .footer__bottom {
    border-top: 1px solid rgba(255,255,255,0.1);
  }

  .footer__bottom-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-block: var(--space-4);
    font-size: var(--text-sm);
    color: rgba(255,255,255,0.5);
  }

  .footer__bottom-links {
    display: flex;
    align-items: center;
    gap: var(--space-5);
  }

  .footer__bottom a {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    color: rgba(255,255,255,0.5);
    text-decoration: none;
    transition: color var(--transition);
  }

  .footer__bottom a:hover {
    color: rgba(255,255,255,0.9);
  }

  .footer__bottom a:hover {
    color: rgba(255,255,255,0.9);
  }

  @media (max-width: 900px) {
    .footer__grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-8);
    }
  }

  @media (max-width: 640px) {
    .footer__grid {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }

    .footer__bottom-inner {
      flex-direction: column;
      gap: var(--space-2);
      text-align: center;
    }
  }
</style>
