---
interface Props {
  quote: string;
  author?: string;
  service?: string;
}

const { quote, author, service } = Astro.props;
---

<figure class="testimonial">
  <svg class="testimonial__quote-icon" viewBox="0 0 32 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" width="32" height="24">
    <path d="M0 24V14.4C0 10.56 0.96 7.28 2.88 4.56 4.8 1.84 7.6 0.24 11.28 0L12 1.92C9.76 2.48 7.96 3.6 6.6 5.28 5.24 6.96 4.56 8.64 4.56 10.32H8.4V24H0ZM19.6 24V14.4C19.6 10.56 20.56 7.28 22.48 4.56 24.4 1.84 27.2 0.24 30.88 0L31.6 1.92C29.36 2.48 27.56 3.6 26.2 5.28 24.84 6.96 24.16 8.64 24.16 10.32H28V24H19.6Z" fill="currentColor"/>
  </svg>
  <blockquote class="testimonial__text">{quote}</blockquote>
  {(author || service) && (
    <figcaption class="testimonial__meta">
      {author && <span class="testimonial__author">{author}</span>}
      {service && <span class="testimonial__service">{service}</span>}
    </figcaption>
  )}
</figure>

<style>
  .testimonial {
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-8);
    position: relative;
  }

  .testimonial__quote-icon {
    color: var(--color-accent);
    opacity: 0.6;
    margin-bottom: var(--space-4);
  }

  .testimonial__text {
    font-family: var(--font-heading);
    font-style: italic;
    font-size: var(--text-base);
    color: var(--color-text);
    line-height: 1.8;
    border: none;
    padding: 0;
    margin: 0 0 var(--space-5);
  }

  .testimonial__meta {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .testimonial__author {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: var(--text-sm);
    color: var(--color-text);
  }

  .testimonial__service {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    color: var(--color-primary);
    font-weight: 400;
  }
</style>
